# Vektra Mobile App — Environment Variables
# Copy this file to .env and fill in actual values

# Production web app URL (the Vercel deployment)
EXPO_PUBLIC_WEB_URL=https://vektra-six.vercel.app

# Backend API (Render deployment)
EXPO_PUBLIC_API_URL=https://vektra-api.onrender.com

# App environment (development | preview | production)
APP_ENV=development
