{
  "expo": {
    "name": "Vektra",
    "slug": "vektra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vektra",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anndus.vektra",
      "infoPlist": {
        "NSCameraUsageDescription": "Vektra uses the camera to capture evidence for forensic investigations.",
        "NSPhotoLibraryUsageDescription": "Vektra accesses your photo library to attach evidence to investigations.",
        "NSMicrophoneUsageDescription": "Vektra uses the microphone for voice-based forensic queries.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#0b0e14"
      },
      "package": "com.anndus.vektra",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0e14",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "acb3f4bc-df30-4894-8349-ed73d3e6ae60"
      },
      "apiUrl": "https://vektra-backend.onrender.com",
      "webUrl": "https://vektra-six.vercel.app"
    },
    "owner": "anndus-organization",
    "updates": {
      "url": "https://u.expo.dev/acb3f4bc-df30-4894-8349-ed73d3e6ae60",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
