{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vektra.onrender.com/api/:path*"
    },
    {
      "source": "/workflow/:path*",
      "destination": "https://vektra.onrender.com/workflow/:path*"
    }
  ]
}
